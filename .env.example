# Azure AI Foundry — projeto existente (nova agents API, Web Search tool nativo)
PROJECT_ENDPOINT=https://omc-cli.services.ai.azure.com/api/projects/omc-ccg-cli
MODEL_DEPLOYMENT_NAME=gpt-5-radar

# Azure Cosmos DB serverless
COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
COSMOS_KEY=<primary-key>

# Pipeline
ANALYSIS_BUDGET_SECONDS=360
MAX_ANALYSES_PER_DAY=10

# Demo offline (R9): descomente para usar repositório em disco (data/reports/) em vez do Cosmos
# RADAR_OFFLINE=1

# arXiv/OpenAlex — identificação recomendada (não obrigatória)
OPENALEX_MAILTO=seu-email@exemplo.com
